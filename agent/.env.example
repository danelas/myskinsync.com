# Agent secrets (set these as GitHub repo secrets; copy to agent/.env for local runs).

# Claude — writes the pin copy. (Same key as ../the-listener/.env)
ANTHROPIC_API_KEY=

# OpenAI — generates the pin background image (gpt-image-1).
OPENAI_API_KEY=

# Upload-Post — schedules/posts the pins. From upload-post.com dashboard.
UPLOAD_POST_API_KEY=
UPLOAD_POST_USER=
# Pinterest board id/name from your Upload-Post Pinterest connection.
PINTEREST_BOARD=

# Optional — defaults to https://myskinsync.com
SITE_URL=https://myskinsync.com

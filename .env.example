# Your Amazon Associates store/tracking ID. Shown in every outbound Amazon link.
NEXT_PUBLIC_AMAZON_TAG=dpop07-20

# Amazon Creators API (live prices) — server-side only, set these in Vercel.
AMAZON_CREDENTIAL_ID=
AMAZON_CREDENTIAL_SECRET=
AMAZON_CREDENTIAL_VERSION=
AMAZON_PARTNER_TAG=dpop07-20
AMAZON_MARKETPLACE=www.amazon.com

# Supabase — email capture ("email me my routine"). Server-side only.
# URL: Supabase → Project Settings → API → Project URL
# Service role key: same page → Project API keys → service_role (SECRET — never NEXT_PUBLIC)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
